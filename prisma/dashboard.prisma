model AuditLog {
  id        String   @id @default(cuid())
  user      String
  action    String
  module    String
  details   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("audit_logs")
}

model Holiday {
  id        String   @id @default(cuid())
  name      String
  type      String   // e.g. National, Regional, Company
  date      DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("holidays")
}
