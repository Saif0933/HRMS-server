model Employee {
  id                 String             @id
  name               String
  email              String             @unique
  phone              String?
  password           String?
  avatar             String?
  status             EmployeeStatus     @default(PROBATION)
  joiningDate        DateTime
  location           String?
  designation        String?
  userId             String?            @unique
  departmentId       String?
  managerId          String?
  basic              Float?
  hra                Float?
  allowance          Float?
  deductions         Float?
  netSalary          Float?
  bankName           String?
  bankAccount        String?
  ifsc               String?
  pan                String?
  aadhaar            String?
  uan                String?
  pfNumber           String?
  gender             String?
  dob                DateTime?
  bloodGroup         String?
  maritalStatus      String?
  qualification      String?
  university         String?
  passingYear        String?
  fatherName         String?
  permanentAddress   String?
  languagesSpoken    String?
  probationDuration  String?
  probationEnd       DateTime?
  confirmationStatus ConfirmationStatus @default(PENDING)
  exitDate           DateTime?
  clearanceStatus    String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  department         Department?        @relation(fields: [departmentId], references: [id])
  manager            Employee?          @relation("ManagerRelation", fields: [managerId], references: [id])
  subordinates       Employee[]         @relation("ManagerRelation")
  user               User?              @relation(fields: [userId], references: [id])
  leaveAllocations   LeaveAllocation[]
  leaveRequests      LeaveRequest[]     @relation("EmployeeLeaveRequests")
  payrollRuns        PayrollRun[]
  payrollExclusions  PayrollExclusion[]
  loans              Loan[]
  taxDeclarations    TaxDeclaration[]
  performanceGoals       PerformanceGoal[]
  performanceFeedbacks   PerformanceFeedback[]
  performanceAppraisals  PerformanceAppraisal[]
  performanceRatings     PerformanceRating[]
  familyMembers          EmployeeFamily[]
  engagementPostLikes     EngagementPostLike[]
  engagementPostReactions EngagementPostReaction[]
  engagementMoods         EngagementMood[]
  surveyResponses         CorporateSurveyResponse[]
  travelClaims            TravelClaim[]
  timesheets              Timesheet[]
  vaultDocuments          VaultDocument[]
  assets                  Asset[]
  helpTickets             HelpTicket[]
  attendancePunches       AttendancePunch[]
  attendanceRegularizations AttendanceRegularization[]
  shiftRosters            ShiftRoster[]
  exitRecord              EmployeeExit?

  @@index([managerId])
  @@index([email])
  @@index([departmentId])
  @@index([status])
  @@map("employees")
}

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  TERMINATED
  RESIGNED
  PROBATION
}

enum ConfirmationStatus {
  PENDING
  CONFIRMED
  EXTENDED
}

model EmployeeFamily {
  id                 String    @id @default(cuid())
  employeeId         String
  name               String
  relation           String    // Spouse, Son, Daughter, Father, Mother, Brother, Sister
  dob                DateTime?
  contact            String?
  bloodGroup         String?
  isNominee          Boolean   @default(false)
  isInsuranceCovered Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  employee           Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("employee_family")
}

model EmployeeExit {
  id                 String    @id @default(cuid())
  employeeId         String    @unique
  resignationDate    DateTime
  lastWorkingDay     DateTime
  reason             String?
  noticeDays         Int       @default(30)
  leaveEncashDays    Int       @default(0)
  penaltyDeduction   Float     @default(0)
  itClearance        Boolean   @default(false)
  financeClearance   Boolean   @default(false)
  adminClearance     Boolean   @default(false)
  hrClearance        Boolean   @default(false)
  status             String    @default("PENDING_CLEARANCE")
  settledDate        DateTime?
  netPayable         Float?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  employee           Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("employee_exits")
}
