model Asset {
  id         String   @id @default(cuid())
  name       String
  category   String // Hardware, Mobile, Keycard, Other
  serial     String
  employeeId String?
  status     String   @default("In Stock") // Assigned, In Stock, Maintenance
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  employee   Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  @@map("assets")
}
