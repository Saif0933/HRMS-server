model Role {
  id          String       @id @default(cuid())
  name        String       @unique // e.g. "SUPER_ADMIN", "HR_ADMIN", "MANAGER", "EMPLOYEE", or custom roles
  description String?
  isSystem    Boolean      @default(false) // System-defined roles cannot be deleted/modified
  permissions Permission[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  users       User[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique // e.g. "users:create", "leaves:approve"
  description String?
  module      String?  // e.g. "User Management", "Leave Management"
  roles       Role[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("permissions")
}
